{
  "methodology": "hybrid",
  "description": "Waterfall phase gates wrapping Agile sprints inside each phase. Phases hard-gate on client sign-off; internal work uses Agile states.",
  "states": [
    { "key": "backlog",     "label": "Backlog",     "category": "todo",        "sort_order": 0 },
    { "key": "in_progress", "label": "In Progress", "category": "in_progress", "sort_order": 10 },
    { "key": "in_review",   "label": "In Review",   "category": "in_progress", "sort_order": 20 },
    { "key": "qa",          "label": "QA",          "category": "in_progress", "sort_order": 30 },
    { "key": "gate_review", "label": "Gate Review", "category": "in_progress", "sort_order": 40 },
    { "key": "blocked",     "label": "Blocked",     "category": "in_progress", "sort_order": 45 },
    { "key": "rejected",    "label": "Rejected",    "category": "in_progress", "sort_order": 50 },
    { "key": "done",        "label": "Done",        "category": "done",        "sort_order": 60 }
  ],
  "transitions": [
    { "from": "backlog",     "to": "in_progress" },
    { "from": "in_progress", "to": "in_review"   },
    { "from": "in_progress", "to": "blocked"     },
    { "from": "in_review",   "to": "in_progress" },
    { "from": "in_review",   "to": "qa"          },
    { "from": "qa",          "to": "in_progress" },
    { "from": "qa",          "to": "gate_review", "required_role": "qa" },
    { "from": "gate_review", "to": "in_progress" },
    { "from": "gate_review", "to": "rejected"    },
    { "from": "rejected",    "to": "in_progress" },
    { "from": "blocked",     "to": "in_progress" },
    { "from": "blocked",     "to": "backlog"     },
    {
      "from": "gate_review",
      "to": "done",
      "is_hard_gate": true,
      "required_role": "project_owner",
      "approval_quorum": { "project_owner": 1, "client_approver": 1 }
    }
  ],
  "hierarchy": [
    { "parent_kind": "phase",       "child_kind": "epic"        },
    { "parent_kind": "phase",       "child_kind": "deliverable" },
    { "parent_kind": "epic",        "child_kind": "feature"     },
    { "parent_kind": "epic",        "child_kind": "story"       },
    { "parent_kind": "feature",     "child_kind": "story"       },
    { "parent_kind": "feature",     "child_kind": "bug"         },
    { "parent_kind": "story",       "child_kind": "task"        },
    { "parent_kind": "story",       "child_kind": "bug"         },
    { "parent_kind": "story",       "child_kind": "test_case"   },
    { "parent_kind": "deliverable", "child_kind": "task"        },
    { "parent_kind": "deliverable", "child_kind": "test_case"   }
  ]
}
