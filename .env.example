# Root-level environment for docker-compose. Copy to .env before `docker compose up`.
# Application-level defaults live in apps/api/.env.example.

# Image tags (bump on release cuts)
KRITITVA_IMAGE_API=krititva/api:local
KRITITVA_IMAGE_WEB=krititva/web:local

# LiteLLM gateway master key (rotate before public deploy)
LITELLM_MASTER_KEY=sk-krititva-local

# Telemetry MUST default to false — non-negotiable (see .claude/CLAUDE.md §1.6)
KRITITVA_TELEMETRY_ENABLED=false
