# Root-level environment for docker-compose. Copy to .env before `docker compose up`.
# Application-level defaults live in apps/api/.env.example.

# Image tags (bump on release cuts)
KRITITVA_IMAGE_API=krititva/api:local
KRITITVA_IMAGE_WEB=krititva/web:local

# LiteLLM gateway master key (rotate before public deploy)
LITELLM_MASTER_KEY=sk-krititva-local

# Telemetry MUST default to false — non-negotiable (see .claude/CLAUDE.md §1.6)
KRITITVA_TELEMETRY_ENABLED=false

# --- Backend secrets — CHANGE these before any real deployment -----------------
# JWT signing key: any long random string. Required in production (the api
# refuses to start with the built-in default). This placeholder is dev-only.
KRITITVA_JWT_SECRET=dev-only-change-me-please-0123456789abcdef
# At-rest encryption key (32-byte base64) for provider/IdP secrets. Optional
# until those features are configured; generate with:
#   python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
KRITITVA_DATA_KEY=
