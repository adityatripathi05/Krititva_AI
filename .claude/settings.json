{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git blame:*)",
      "Bash(git stash list)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(uv run:*)",
      "Bash(uv sync)",
      "Bash(uv lock)",
      "Bash(uv add:*)",
      "Bash(pnpm install)",
      "Bash(pnpm run:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm build)",
      "Bash(pnpm lint)",
      "Bash(pnpm tsc:*)",
      "Bash(pnpm dlx:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(alembic upgrade:*)",
      "Bash(alembic downgrade:*)",
      "Bash(alembic history:*)",
      "Bash(alembic current)",
      "Bash(alembic revision:*)",
      "Bash(docker compose ps)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose config)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(rm -rf:*)",
      "Bash(docker system prune:*)",
      "Bash(docker volume rm:*)"
    ]
  },
  "env": {
    "KRITITVA_TELEMETRY_ENABLED": "false"
  }
}
