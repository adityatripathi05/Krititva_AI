KRITITVA_ENVIRONMENT=development
KRITITVA_DEBUG=false
KRITITVA_LOG_LEVEL=info
KRITITVA_PUBLIC_BASE_URL=http://localhost:8000
KRITITVA_TELEMETRY_ENABLED=false

POSTGRES_DSN=postgresql+asyncpg://krititva:krititva@localhost:5432/krititva
REDIS_URL=redis://localhost:6379/0
LITELLM_URL=http://localhost:4000

# 32 bytes, base64-encoded. Generate: openssl rand -base64 32
KRITITVA_DATA_KEY=

# Per-organization rate limiting (NFR-5.2.5). Needs Redis; no-ops without it.
KRITITVA_RATE_LIMIT_ENABLED=true
KRITITVA_ORG_RPS=100
KRITITVA_RATE_LIMIT_WINDOW_S=1
